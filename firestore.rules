rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    function isOperator() {
      return isAuth() &&
        get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data.role == 'operator';
    }

    function isVisible(res) {
      return res.data.hidden == false && res.data.removed == false;
    }

    function isNotBanned() {
      return get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data.banned == false;
    }

    // sports: public read, operator write
    match /sports/{sportId} {
      allow read: if true;
      allow write: if isOperator();
    }

    // competitions: public read, operator write
    match /competitions/{compId} {
      allow read: if true;
      allow write: if isOperator();
    }

    // teams: public read, operator write
    match /teams/{teamId} {
      allow read: if true;
      allow write: if isOperator();
    }

    // players: public read, operator write
    match /players/{playerId} {
      allow read: if true;
      allow write: if isOperator();
    }

    // profiles: public read, owner create (role and banned pinned), owner update (cannot change role or banned)
    match /profiles/{userId} {
      allow read: if true;
      allow create: if isAuth() && request.auth.uid == userId
        && request.resource.data.role == 'user'
        && request.resource.data.banned == false
        && request.resource.data.displayName is string
        && request.resource.data.displayName.size() > 0
        && request.resource.data.displayName.size() <= 50
        && request.resource.data.createdAt is timestamp
        && request.resource.data.updatedAt is timestamp;
      allow update: if isAuth() && request.auth.uid == userId
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'banned']);
    }

    // chants: public read (visible only), auth create (not banned, server-side length limits), restricted update
    match /chants/{chantId} {
      allow read: if isVisible(resource) || isOperator();
      allow create: if isAuth()
        && isNotBanned()
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.status == 'community'
        && request.resource.data.upvotes == 0
        && request.resource.data.downvotes == 0
        && request.resource.data.score == 0
        && request.resource.data.commentCount == 0
        && request.resource.data.flagCount == 0
        && request.resource.data.hidden == false
        && request.resource.data.removed == false
        && request.resource.data.title is string
        && request.resource.data.title.size() > 0
        && request.resource.data.title.size() <= 200
        && request.resource.data.lyrics is string
        && request.resource.data.lyrics.size() > 0
        && request.resource.data.lyrics.size() <= 5000
        && request.resource.data.tuneName is string
        && request.resource.data.tuneName.size() > 0
        && request.resource.data.tuneName.size() <= 200
        && (request.resource.data.contextNotes == null
            || request.resource.data.contextNotes.size() <= 500);
      // Author can update content fields only, never counters/status/hidden/removed
      allow update: if isAuth()
        && resource.data.createdBy == request.auth.uid
        && !request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(['upvotes','downvotes','score','commentCount',
                     'flagCount','hidden','removed','status','createdBy','createdAt']);
      // Operator can update anything (moderation, promote to canonical)
      allow update: if isOperator();
    }

    // votes: one per user per chant, value 1 or -1, not banned
    match /votes/{voteId} {
      allow read: if true;
      allow create: if isAuth()
        && isNotBanned()
        && request.resource.data.userId == request.auth.uid
        && voteId == request.auth.uid + '_' + request.resource.data.chantId
        && (request.resource.data.value == 1 || request.resource.data.value == -1);
      allow update: if isAuth()
        && isNotBanned()
        && resource.data.userId == request.auth.uid
        && (request.resource.data.value == 1 || request.resource.data.value == -1)
        && !request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(['userId','chantId']);
      allow delete: if isAuth() && resource.data.userId == request.auth.uid;
    }

    // reports: one per user per chant (doc ID = userId_chantId), not banned, insert-only
    match /reports/{reportId} {
      allow read: if isOperator();
      allow create: if isAuth()
        && isNotBanned()
        && request.resource.data.reportedBy == request.auth.uid
        && request.resource.data.status == 'pending'
        && reportId == request.auth.uid + '_' + request.resource.data.chantId;
    }

    // auditLog: no client writes (Cloud Functions use Admin SDK), operator read
    match /auditLog/{logId} {
      allow read: if isOperator();
      allow write: if false;
    }

    // comments: visible to all, auth create (not banned, body <= 500),
    // author can soft-delete own (set removed: true), operator can update anything
    match /comments/{commentId} {
      allow read: if isVisible(resource) || isOperator();
      allow create: if isAuth()
        && isNotBanned()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.displayName is string
        && request.resource.data.displayName.size() > 0
        && request.resource.data.body is string
        && request.resource.data.body.size() > 0
        && request.resource.data.body.size() <= 500
        && request.resource.data.likeCount == 0
        && request.resource.data.flagCount == 0
        && request.resource.data.hidden == false
        && request.resource.data.removed == false;
      // Author can only soft-delete (set removed: true on their own comment)
      allow update: if isAuth()
        && resource.data.userId == request.auth.uid
        && request.resource.data.removed == true
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['removed']);
      // Operator can update anything (moderation: hide, unhide, remove, reset flagCount)
      allow update: if isOperator();
    }

    // commentLikes: one per user per comment (doc ID = userId_commentId), value always 1, not banned
    match /commentLikes/{likeId} {
      allow read: if true;
      allow create: if isAuth()
        && isNotBanned()
        && request.resource.data.userId == request.auth.uid
        && likeId == request.auth.uid + '_' + request.resource.data.commentId
        && request.resource.data.value == 1;
      allow update: if isAuth()
        && isNotBanned()
        && resource.data.userId == request.auth.uid
        && request.resource.data.value == 1
        && !request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(['userId','commentId']);
      allow delete: if isAuth() && resource.data.userId == request.auth.uid;
    }

    // commentReports: one per user per comment (doc ID = userId_commentId), not banned, insert-only
    match /commentReports/{reportId} {
      allow read: if isOperator();
      allow create: if isAuth()
        && isNotBanned()
        && request.resource.data.reportedBy == request.auth.uid
        && request.resource.data.status == 'pending'
        && reportId == request.auth.uid + '_' + request.resource.data.commentId;
    }

    // feedback: auth create, user reads own, operator reads all
    match /feedback/{feedbackId} {
      allow read: if isOperator()
        || (isAuth() && resource.data.userId == request.auth.uid);
      allow create: if isAuth()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.message.size() <= 1000
        && request.resource.data.resolved == false;
      allow update, delete: if false;
    }
  }
}
