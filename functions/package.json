{
  "name": "chants-functions",
  "description": "Cloud Functions for Chants",
  "scripts": {
    "build": "tsc",
    "serve": "npm run build && firebase emulators:start --only functions",
    "shell": "npm run build && firebase functions:shell",
    "start": "npm run shell",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log",
    "test": "tsc -p tsconfig.test.json && mocha --timeout 10000 lib-test/test/**/*.test.js"
  },
  "engines": {
    "node": "20"
  },
  "type": "commonjs",
  "main": "lib/index.js",
  "dependencies": {
    "firebase-admin": "^13.0.0",
    "firebase-functions": "^6.3.0"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.0",
    "firebase-functions-test": "^3.4.0",
    "mocha": "^11.0.0",
    "ts-mocha": "^11.1.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.7.0"
  },
  "private": true
}
